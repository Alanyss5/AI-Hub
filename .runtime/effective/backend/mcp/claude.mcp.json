{
  "mcpServers": {
    "context7": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "coplay-mcp": {
      "command": "uvx",
      "args": [
        "--python",
        "\u003E=3.11",
        "coplay-mcp-server@latest"
      ],
      "env": {
        "MCP_TOOL_TIMEOUT": "720000"
      }
    }
  }
}