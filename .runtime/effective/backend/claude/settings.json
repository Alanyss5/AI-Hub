{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File C:\\\\AI-Hub\\scripts\\hooks\\session-start.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File C:\\AI-Hub\\scripts\\hooks\\pre-tool-check.ps1 -Profile backend"
          }
        ]
      }
    ]
  }
}