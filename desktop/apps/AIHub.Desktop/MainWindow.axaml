<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AIHub.Desktop.ViewModels"
        xmlns:tabs="using:AIHub.Desktop.Views.Tabs"
        x:Class="AIHub.Desktop.MainWindow"
        mc:Ignorable="d"
        Width="1280"
        Height="760"
        MinWidth="1024"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Title="{Binding AppTitle}"
        Background="{DynamicResource WindowBackgroundBrush}">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*" Margin="16">
    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceElevatedBrush}"
            CornerRadius="16"
            Padding="10,7"
            Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="8"
                  Height="7"
                  CornerRadius="999"
                  Background="{DynamicResource AccentBrush}"
                  VerticalAlignment="Center" />
          <StackPanel Spacing="0" VerticalAlignment="Center">
            <TextBlock Text="{Binding Text.Shell.HeroTitle}" FontSize="13" FontWeight="SemiBold" />
            <TextBlock Text="{Binding HubStatus}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" MaxWidth="620" />
          </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="999" Padding="9,4">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="{Binding Text.Shell.ActiveScopeLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
              <TextBlock Text="{Binding ActiveScopeDisplay}" FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Button x:Name="RefreshAllButton"
                  Content="{Binding Text.Shell.RefreshAllButton}"
                  Command="{Binding RefreshCommand}"
                  Background="{DynamicResource AccentBrush}"
                  Foreground="{DynamicResource AccentForegroundBrush}"
                  Padding="10,5" />
        </StackPanel>
      </Grid>
    </Border>

    <TabControl Grid.Row="1" Background="Transparent">
      <TabItem x:Name="OverviewTab" Header="{Binding Text.Shell.OverviewTabHeader}">
        <tabs:OverviewTabView />
      </TabItem>
      <TabItem x:Name="ProjectsTab" Header="{Binding Text.Projects.TabHeader}">
        <tabs:ProjectsTabView DataContext="{Binding ProjectsPage}" />
      </TabItem>
      <TabItem x:Name="WorkspaceTab" Header="{Binding Text.Shell.WorkspaceTabHeader}">
        <tabs:WorkspaceTabView DataContext="{Binding WorkspacePage}" />
      </TabItem>
      <TabItem x:Name="SkillsTab" Header="{Binding Text.Skills.TabHeader}">
        <tabs:SkillsTabView DataContext="{Binding SkillsPage}" />
      </TabItem>
      <TabItem x:Name="ScriptsTab" Header="{Binding Text.Scripts.TabHeader}">
        <tabs:ScriptsTabView />
      </TabItem>
      <TabItem x:Name="McpTab" Header="{Binding Text.Mcp.TabHeader}">
        <tabs:McpTabView DataContext="{Binding McpPage}" />
      </TabItem>
      <TabItem x:Name="SettingsTab" Header="{Binding Text.Settings.TabHeader}">
        <tabs:SettingsTabView />
      </TabItem>
    </TabControl>
  </Grid>
</Window>
