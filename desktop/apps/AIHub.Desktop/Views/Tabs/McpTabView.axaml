<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.McpTabView">
  <UserControl.Styles>
    <Style Selector="TabControl.side-nav TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="MinWidth" Value="84" />
    </Style>
    <Style Selector="TabControl.compact-tabs TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="MinHeight" Value="26" />
    </Style>
  </UserControl.Styles>
  <ScrollViewer Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
      <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
        <Grid ColumnDefinitions="Auto,Auto,220,*" ColumnSpacing="10">
          <StackPanel Spacing="4">
            <TextBlock Text="当前范围" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Context.CurrentScopeDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
          <Button x:Name="McpSwitchProjectScopeButton"
                  Grid.Column="1"
                  Content="项目范围"
                  Command="{Binding Context.SwitchToSelectedProjectScopeCommand}"
                  IsEnabled="{Binding Context.HasSelectedProject}"
                  Background="{DynamicResource InfoBrush}"
                  Foreground="{DynamicResource AccentForegroundBrush}" />
          <Button x:Name="McpSwitchGlobalScopeButton"
                  Grid.Column="2"
                  Content="全局范围"
                  Command="{Binding Context.SwitchToGlobalScopeCommand}"
                  Background="{DynamicResource NeutralButtonBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}" />
          <StackPanel Grid.Column="3" Spacing="4">
            <TextBlock Text="当前项目" FontWeight="SemiBold" />
            <ComboBox x:Name="McpContextProjectComboBox"
                      ItemsSource="{Binding Context.Projects}"
                      SelectedItem="{Binding Context.SelectedProject}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Grid>
      </Border>

      <TabControl Grid.Row="2" DataContext="{Binding Vm}" Classes="side-nav" Background="Transparent" SelectedIndex="{Binding SelectedMcpSectionIndex, Mode=TwoWay}" TabStripPlacement="Left">
        <TabItem Header="概览">
          <Grid Margin="0,6,0,0" RowDefinitions="Auto,*" RowSpacing="12">
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
              <Grid ColumnDefinitions="1.3*,0.9*" ColumnSpacing="12">
                <StackPanel Spacing="8">
                  <TextBlock Text="MCP 控制中心" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="在一个页面中查看当前 Profile、生成配置和托管进程。" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding McpRuntimeSummaryDisplay}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding McpManagedProcessDetails}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Text="当前对象" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedMcpProfile.DisplayName, TargetNullValue=未选择 Profile}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding McpValidationScopeDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding McpManifestPathDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
            <Grid Grid.Row="1" ColumnDefinitions="248,*,256" ColumnSpacing="12">
              <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Profile 列表" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="从目录中选择一个 Profile，查看它的 Server 覆盖和当前范围。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <ListBox Grid.Row="1" ItemsSource="{Binding McpProfiles}" SelectedItem="{Binding SelectedMcpProfile}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding ServerCountDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" />
                            <TextBlock Text="{Binding ServerNamesSummary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
                <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="12">
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
                    <StackPanel Spacing="6">
                      <TextBlock Text="配置状态" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding McpServerSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding McpManifestPathDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
                    <StackPanel Spacing="6">
                      <TextBlock Text="校验范围" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding McpValidationScopeDisplay}" TextWrapping="Wrap" />
                      <TextBlock Text="生成、同步和校验动作都会作用于当前范围。" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>
                  <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                      <StackPanel Spacing="4">
                        <TextBlock Text="Server 状态卡片" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="核心 Server 信息集中展示，不再埋在长表单里。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      </StackPanel>
                      <Border Grid.Row="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12">
                        <StackPanel Spacing="6">
                          <TextBlock Text="Server 摘要" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding McpServerSummary}" TextWrapping="Wrap" />
                          <TextBlock Text="如需编辑归属和 JSON，请打开“Server 绑定”。" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                      <StackPanel Spacing="4">
                        <TextBlock Text="托管进程概览" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="这里集中展示托管进程摘要；详细维护操作放在最后一个标签页。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      </StackPanel>
                      <ListBox Grid.Row="1" ItemsSource="{Binding ManagedProcesses}" SelectedItem="{Binding SelectedManagedProcess}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="{Binding StatusDisplay}" FontSize="12" Foreground="{DynamicResource WarningBrush}" />
                                <TextBlock Text="{Binding HealthDisplay}" FontSize="12" Foreground="{DynamicResource SuccessBrush}" />
                                <TextBlock Text="{Binding CommandDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Grid>
                  </Border>
                </Grid>
              </Grid>
              <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="当前 Profile 面板" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="这个面板会集中展示当前 Profile 摘要和常用动作。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <Border Grid.Row="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12">
                    <StackPanel Spacing="6">
                      <TextBlock Text="当前 Profile" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedMcpProfile.DisplayName, TargetNullValue=未选择 Profile}" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding McpValidationScopeDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                  <WrapPanel Grid.Row="2">
                    <Button Content="生成配置" Command="{Binding GenerateMcpConfigsCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                    <Button Content="校验当前范围" Command="{Binding ValidateCurrentMcpScopeCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                    <Button Content="同步客户端" Command="{Binding SyncCurrentMcpClientsCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  </WrapPanel>
                  <Border Grid.Row="3" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14">
                    <StackPanel Spacing="6">
                      <TextBlock Text="当前托管进程" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedManagedProcess.Name, TargetNullValue=未选择托管进程}" />
                      <TextBlock Text="{Binding McpRuntimeSummaryDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>
        <TabItem Header="Server 绑定">
          <Grid Margin="0,6,0,0" ColumnDefinitions="248,292,*" ColumnSpacing="12">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="14">
              <Grid RowDefinitions="Auto,*" RowSpacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Server 卡片" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="先在这里选择一个 Server，再在中间区域调整它属于哪些 Profile。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding McpServers}" SelectedItem="{Binding SelectedMcpServer}" BorderThickness="0" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                          <TextBlock Text="{Binding ProfileSummary}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="16">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="绑定控制台" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="勾选一个 Profile 即添加，取消勾选即移除。一个 Server 可属于多个 Profile。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Spacing="6">
                    <TextBlock Text="Server 名称" FontWeight="SemiBold" />
                    <TextBox Text="{Binding McpServerName}" Watermark="例如：filesystem" />
                  </StackPanel>
                <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="18" Padding="14">
                  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="14" Padding="12">
                      <StackPanel Spacing="4">
                        <TextBlock Text="当前归属" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedMcpServer.ProfileSummary, TargetNullValue=未选择 Server}" TextWrapping="Wrap" Foreground="{DynamicResource WarningBrush}" />
                      </StackPanel>
                    </Border>
                    <TextBlock Grid.Row="1" Text="绑定到这些 Profile" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding McpServerBindingProfiles}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                              <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>
                <WrapPanel Grid.Row="3">
                  <Button x:Name="McpSaveServerBindingsButton" Content="保存 Server 绑定" Command="{Binding SaveMcpServerBindingsCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="清空当前选择" Command="{Binding ClearMcpServerSelectionCommand}" Background="{DynamicResource NeutralButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                </WrapPanel>
              </Grid>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="16">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="单个 Server 编辑器" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="右侧专注显示单个 Server 的 JSON、摘要和最终覆盖结果。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Row="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="当前摘要" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedMcpServer.ProfileSummary, TargetNullValue=请先从左侧选择一个 Server}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <TextBox Grid.Row="2" Text="{Binding McpServerEditor}" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="520" />
              </Grid>
            </Border>
          </Grid>
        </TabItem>
        <TabItem Header="Manifest">
          <Grid Margin="0,8,0,0" RowDefinitions="Auto,*,Auto" RowSpacing="16">
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
              <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="Manifest 编辑器" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding McpManifestPathDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="当前 Profile" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedMcpProfile.DisplayName, TargetNullValue=未选择 Profile}" />
                    <TextBlock Text="{Binding McpServerSummary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
              <TextBox Text="{Binding McpManifestEditor}" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="620" />
            </Border>
            <WrapPanel Grid.Row="2">
               <Button x:Name="McpSaveManifestButton" Content="保存 Manifest" Command="{Binding SaveMcpManifestCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
               <Button Content="生成配置" Command="{Binding GenerateMcpConfigsCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
               <Button Content="校验当前范围" Command="{Binding ValidateCurrentMcpScopeCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
               <Button Content="同步客户端" Command="{Binding SyncCurrentMcpClientsCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
            </WrapPanel>
          </Grid>
        </TabItem>
        <TabItem Header="校验">
          <Grid Margin="0,8,0,0" ColumnDefinitions="1.1*,0.9*" ColumnSpacing="18">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
              <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <StackPanel Spacing="6">
                  <TextBlock Text="校验摘要" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding McpValidationSummaryDisplay}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding McpValidationScopeDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <TextBlock Text="客户端状态" FontSize="16" FontWeight="SemiBold" />
                  <ItemsControl Grid.Row="1" ItemsSource="{Binding McpClientStatuses}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Client}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding FilePath}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
              <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <TextBlock Text="校验问题" FontSize="16" FontWeight="SemiBold" />
                  <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding McpValidationIssues}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Severity}" FontSize="12" Foreground="{DynamicResource WarningBrush}" />
                              <TextBlock Text="{Binding Details}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding FilePath}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>
            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="16">
              <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                  <TextBlock Text="外部导入" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Grid.Row="1" Text="{Binding Text.Mcp.ExternalImportDescription}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <StackPanel Grid.Row="2" Spacing="10">
                    <CheckBox Content="{Binding Text.Mcp.SyncImportedClientsLabel}" IsChecked="{Binding SyncImportedExternalServers}" />
                    <Button Content="{Binding Text.Mcp.ImportSelectedButton}" Command="{Binding ImportExternalMcpCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Left" />
                  </StackPanel>
                </Grid>
              </Border>
              <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <TextBlock Text="外部 Server 选项" FontSize="16" FontWeight="SemiBold" />
                  <ScrollViewer Grid.Row="1" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding McpExternalServerImports}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                            <StackPanel Spacing="6">
                              <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding ConflictDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                              <ComboBox ItemsSource="{Binding VariantOptions}" SelectedItem="{Binding SelectedVariantOption}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
              <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <TextBlock Text="已生成的客户端配置" FontSize="16" FontWeight="SemiBold" />
                  <TabControl Grid.Row="1" Classes="compact-tabs" Background="Transparent">
                    <TabItem Header="Claude">
                      <Grid Margin="0,12,0,0" RowDefinitions="Auto,*" RowSpacing="10">
                        <TextBlock Text="{Binding McpClaudePathDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBox Grid.Row="1" Text="{Binding McpClaudePreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" />
                      </Grid>
                    </TabItem>
                    <TabItem Header="Codex">
                      <Grid Margin="0,12,0,0" RowDefinitions="Auto,*" RowSpacing="10">
                        <TextBlock Text="{Binding McpCodexPathDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBox Grid.Row="1" Text="{Binding McpCodexPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" />
                      </Grid>
                    </TabItem>
                    <TabItem Header="Antigravity">
                      <Grid Margin="0,12,0,0" RowDefinitions="Auto,*" RowSpacing="10">
                        <TextBlock Text="{Binding McpAntigravityPathDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBox Grid.Row="1" Text="{Binding McpAntigravityPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" />
                      </Grid>
                    </TabItem>
                  </TabControl>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>
        <TabItem Header="托管进程">
          <Grid Margin="0,8,0,0" RowDefinitions="Auto,*" RowSpacing="16">
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
              <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="托管进程控制" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="在一个 Workspace 标签页里创建、查看和操作长期运行的 MCP 辅助进程。" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding McpRuntimeSummaryDisplay}" FontWeight="SemiBold" />
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="当前进程" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedManagedProcess.Name, TargetNullValue=未选择托管进程}" />
                    <TextBlock Text="{Binding ManagedProcessStatusDisplay}" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ManagedProcessHealthStatusDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
            <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="18">
              <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="托管进程列表" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="在左侧选择一个进程后，可查看状态、健康情况、命令细节和维护操作。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                  <ListBox Grid.Row="1" ItemsSource="{Binding ManagedProcesses}" SelectedItem="{Binding SelectedManagedProcess}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding StatusDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" />
                            <TextBlock Text="{Binding HealthDisplay}" FontSize="13" Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text="{Binding CommandDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
              <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                  <Grid ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="6"><TextBlock Text="进程名称" FontWeight="SemiBold" /><TextBox Text="{Binding ManagedProcessName}" /></StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6"><TextBlock Text="命令" FontWeight="SemiBold" /><TextBox Text="{Binding ManagedProcessCommand}" /></StackPanel>
                    <StackPanel Grid.ColumnSpan="2" Spacing="6"><TextBlock Text="参数" FontWeight="SemiBold" /><TextBox Text="{Binding ManagedProcessArgumentsText}" /></StackPanel>
                    <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <StackPanel Grid.Column="0" Spacing="6"><TextBlock Text="工作目录" FontWeight="SemiBold" /><TextBox Text="{Binding ManagedProcessWorkingDirectory}" /></StackPanel>
                      <Button Grid.Column="1" Content="选择目录" Command="{Binding ChooseManagedProcessWorkingDirectoryCommand}" Background="{DynamicResource NeutralButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,8" VerticalAlignment="Bottom" />
                    </Grid>
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16">
                      <CheckBox Content="{Binding Text.Mcp.ManagedProcessEnabledLabel}" IsChecked="{Binding ManagedProcessEnabled}" />
                      <CheckBox Content="{Binding Text.Mcp.ManagedProcessAutoStartLabel}" IsChecked="{Binding ManagedProcessAutoStart}" />
                      <CheckBox Content="{Binding Text.Mcp.ManagedProcessKeepAliveLabel}" IsChecked="{Binding ManagedProcessKeepAlive}" />
                    </StackPanel>
                    <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,160" ColumnSpacing="16">
                      <StackPanel Grid.Column="0" Spacing="6"><TextBlock Text="健康检查 URL" FontWeight="SemiBold" /><TextBox Text="{Binding ManagedProcessHealthCheckUrl}" /></StackPanel>
                      <StackPanel Grid.Column="1" Spacing="6"><TextBlock Text="健康超时（秒）" FontWeight="SemiBold" /><TextBox Text="{Binding ManagedProcessHealthTimeoutText}" /></StackPanel>
                    </Grid>
                  </Grid>
                </Border>
                <WrapPanel Grid.Row="1">
                  <Button Content="保存进程" Command="{Binding SaveManagedProcessCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="启动进程" Command="{Binding StartManagedProcessCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="停止进程" Command="{Binding StopManagedProcessCommand}" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="重启进程" Command="{Binding RestartManagedProcessCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="执行健康检查" Command="{Binding RunManagedProcessHealthCheckCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="启动全部" Command="{Binding StartAllManagedProcessesCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="停止全部" Command="{Binding StopAllManagedProcessesCommand}" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="执行进程自恢复" Command="{Binding MaintainManagedProcessesCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button x:Name="McpResumeSuspendedButton" Content="恢复暂停项" Command="{Binding ResumeSuspendedManagedProcessesCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="删除进程" Command="{Binding DeleteManagedProcessCommand}" Background="{DynamicResource NeutralButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="清空表单" Command="{Binding ClearManagedProcessFormCommand}" Background="{DynamicResource NeutralButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                </WrapPanel>
                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                  <StackPanel Spacing="6">
                    <TextBlock Text="当前状态" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ManagedProcessStatusDisplay}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ManagedProcessHealthStatusDisplay}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding ManagedProcessLastMessageDisplay}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                </Border>
                <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="22" Padding="18">
                  <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <TextBlock Text="进程输出" FontSize="16" FontWeight="SemiBold" />
                    <TabControl Grid.Row="1" Classes="compact-tabs" Background="Transparent">
                      <TabItem Header="标准输出"><TextBox Margin="0,12,0,0" Text="{Binding ManagedProcessOutputPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" /></TabItem>
                      <TabItem Header="标准错误"><TextBox Margin="0,12,0,0" Text="{Binding ManagedProcessErrorPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" /></TabItem>
                    </TabControl>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </TabItem>
      </TabControl>
    </Grid>
  </ScrollViewer>
</UserControl>

