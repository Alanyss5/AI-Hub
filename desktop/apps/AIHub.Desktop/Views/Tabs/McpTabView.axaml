<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.McpTabView">
  <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
    <Grid ColumnDefinitions="340,*" ColumnSpacing="20">
      <Grid Grid.Column="0" RowDefinitions="Auto,*,*" RowSpacing="16">
        <Border Grid.Row="0" Background="#FFFDF8" CornerRadius="20" Padding="20">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding Text.Mcp.RuntimeOverviewTitle}" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding McpRuntimeSummaryDisplay}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding McpManagedProcessDetails}" TextWrapping="Wrap" Foreground="#486581" />
          </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="#FFFDF8" CornerRadius="20" Padding="20">
          <Grid RowDefinitions="Auto,*" RowSpacing="12">
            <StackPanel Grid.Row="0" Spacing="4">
              <TextBlock Text="{Binding Text.Mcp.ManagedProcessesTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Text.Mcp.ManagedProcessesDescription}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
            </StackPanel>
            <ListBox Grid.Row="1" ItemsSource="{Binding ManagedProcesses}" SelectedItem="{Binding SelectedManagedProcess}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Background="#F8F4EA" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                      <TextBlock Text="{Binding StatusDisplay}" FontSize="12" Foreground="#7B341E" />
                      <TextBlock Text="{Binding HealthDisplay}" FontSize="12" Foreground="#2F855A" />
                      <TextBlock Text="{Binding SupervisorDisplay}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding LastExitDisplay}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding AutoStartDisplay}" FontSize="12" Foreground="#486581" />
                      <TextBlock Text="{Binding CommandDisplay}" TextWrapping="Wrap" FontSize="12" Foreground="#102A43" />
                      <TextBlock Text="{Binding LastMessageDisplay}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
        <Border Grid.Row="2" Background="#FFFDF8" CornerRadius="20" Padding="20">
          <Grid RowDefinitions="Auto,*" RowSpacing="12">
            <StackPanel Grid.Row="0" Spacing="4">
              <TextBlock Text="{Binding Text.Mcp.ProfileListTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Text.Mcp.ProfileListDescription}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
            </StackPanel>
            <ListBox Grid.Row="1" ItemsSource="{Binding McpProfiles}" SelectedItem="{Binding SelectedMcpProfile}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Background="#F8F4EA" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                      <TextBlock Text="{Binding ServerCountDisplay}" FontSize="12" Foreground="#7B341E" />
                      <TextBlock Text="{Binding ServerNamesSummary}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>

      <TabControl Grid.Column="1" Background="Transparent">
        <TabItem Header="{Binding Text.Mcp.ManagedProcessTabHeader}">
          <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16" Margin="0,8,0,0">
            <Border Grid.Row="0" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Mcp.CurrentStatusTitle}" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ManagedProcessStatusDisplay}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ManagedProcessLastMessageDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                  <TextBlock Text="{Binding SelectedManagedProcess.KeepAliveDisplay}" FontSize="12" Foreground="#486581" />
                  <TextBlock Text="{Binding SelectedManagedProcess.RestartDisplay}" FontSize="12" Foreground="#486581" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Text="{Binding Text.Mcp.HealthStatusTitle}" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ManagedProcessHealthStatusDisplay}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedManagedProcess.SupervisorDisplay}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                  <TextBlock Text="{Binding SelectedManagedProcess.LastExitDisplay}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                  <TextBlock Text="{Binding ManagedProcessOutputLogPath}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                  <TextBlock Text="{Binding ManagedProcessErrorLogPath}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                </StackPanel>
              </Grid>
            </Border>
            <Border Grid.Row="1" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid ColumnDefinitions="*,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                  <TextBlock Text="{Binding Text.Mcp.NameLabel}" FontWeight="SemiBold" />
                  <TextBox Text="{Binding ManagedProcessName}" Watermark="{Binding Text.Mcp.NameWatermark}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                  <TextBlock Text="{Binding Text.Mcp.StartCommandLabel}" FontWeight="SemiBold" />
                  <TextBox Text="{Binding ManagedProcessCommand}" Watermark="{Binding Text.Mcp.StartCommandWatermark}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="6" Margin="0,12,0,0">
                  <TextBlock Text="{Binding Text.Mcp.ArgumentsLabel}" FontWeight="SemiBold" />
                  <TextBox Text="{Binding ManagedProcessArgumentsText}" Watermark="{Binding Text.Mcp.ArgumentsWatermark}" TextWrapping="Wrap" />
                </StackPanel>
                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,12,0,0">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding Text.Mcp.WorkingDirectoryLabel}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding ManagedProcessWorkingDirectory}" Watermark="{Binding Text.Mcp.WorkingDirectoryWatermark}" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="{Binding Text.Mcp.ChooseDirectoryButton}" Command="{Binding ChooseManagedProcessWorkingDirectoryCommand}" Background="#D9E2EC" Foreground="#102A43" Padding="16,8" VerticalAlignment="Bottom" />
                </Grid>
                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16" Margin="0,12,0,0">
                  <CheckBox Content="{Binding Text.Mcp.ManagedProcessEnabledLabel}" IsChecked="{Binding ManagedProcessEnabled}" />
                  <CheckBox Content="{Binding Text.Mcp.ManagedProcessAutoStartLabel}" IsChecked="{Binding ManagedProcessAutoStart}" />
                  <CheckBox Content="{Binding Text.Mcp.ManagedProcessKeepAliveLabel}" IsChecked="{Binding ManagedProcessKeepAlive}" />
                </StackPanel>
                <Grid Grid.Row="4" Grid.ColumnSpan="2" ColumnDefinitions="*,160" ColumnSpacing="16" Margin="0,12,0,0">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding Text.Mcp.HealthCheckAddressLabel}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding ManagedProcessHealthCheckUrl}" Watermark="{Binding Text.Mcp.HealthCheckAddressWatermark}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="{Binding Text.Mcp.HealthCheckTimeoutLabel}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding ManagedProcessHealthTimeoutText}" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>
            <WrapPanel Grid.Row="2">
              <Button Content="{Binding Text.Mcp.SaveDefinitionButton}" Command="{Binding SaveManagedProcessCommand}" Background="#1F487E" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.StartButton}" Command="{Binding StartManagedProcessCommand}" Background="#2F855A" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.StopButton}" Command="{Binding StopManagedProcessCommand}" Background="#C05621" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.RestartButton}" Command="{Binding RestartManagedProcessCommand}" Background="#B7791F" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.HealthCheckButton}" Command="{Binding RunManagedProcessHealthCheckCommand}" Background="#285E61" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.StartAllButton}" Command="{Binding StartAllManagedProcessesCommand}" Background="#2F855A" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.StopAllButton}" Command="{Binding StopAllManagedProcessesCommand}" Background="#C05621" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.MaintainButton}" Command="{Binding MaintainManagedProcessesCommand}" Background="#285E61" Foreground="White" Margin="0,0,12,12" />
              <Button x:Name="McpResumeSuspendedButton" Content="恢复被监督暂停的 MCP" Command="{Binding ResumeSuspendedManagedProcessesCommand}" Background="#805AD5" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.DeleteDefinitionButton}" Command="{Binding DeleteManagedProcessCommand}" Background="#D9E2EC" Foreground="#102A43" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Mcp.ClearFormButton}" Command="{Binding ClearManagedProcessFormCommand}" Background="#D9E2EC" Foreground="#102A43" Margin="0,0,12,12" />
            </WrapPanel>
            <Border Grid.Row="3" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <TextBlock Grid.Row="0" Text="{Binding Text.Mcp.LogPreviewTitle}" FontSize="16" FontWeight="SemiBold" />
                <TabControl Grid.Row="1">
                  <TabItem Header="{Binding Text.Mcp.StandardOutputTabHeader}">
                    <TextBox Margin="0,12,0,0" Text="{Binding ManagedProcessOutputPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" />
                  </TabItem>
                  <TabItem Header="{Binding Text.Mcp.StandardErrorTabHeader}">
                    <TextBox Margin="0,12,0,0" Text="{Binding ManagedProcessErrorPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="220" />
                  </TabItem>
                </TabControl>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="{Binding Text.Mcp.ConfigTabHeader}">
          <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16" Margin="0,8,0,0">
            <Border Grid.Row="0" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="12">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Mcp.CurrentProfileTitle}" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding McpManifestPathDisplay}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding McpServerSummary}" TextWrapping="Wrap" Foreground="#486581" />
                  <TextBlock Text="{Binding McpValidationScopeDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                </StackPanel>
                <Button x:Name="McpSaveManifestButton" Grid.Column="1" Content="{Binding Text.Mcp.SaveManifestButton}" Command="{Binding SaveMcpManifestCommand}" Background="#2F855A" Foreground="White" Padding="16,10" VerticalAlignment="Top" />
                <Button Grid.Column="2" Content="{Binding Text.Mcp.GenerateConfigsButton}" Command="{Binding GenerateMcpConfigsCommand}" Background="#1F487E" Foreground="White" Padding="16,10" VerticalAlignment="Top" />
                <Button Grid.Column="3" Content="{Binding Text.Mcp.ValidateScopeButton}" Command="{Binding ValidateCurrentMcpScopeCommand}" Background="#285E61" Foreground="White" Padding="16,10" VerticalAlignment="Top" />
                <Button Grid.Column="4" Content="{Binding Text.Mcp.SyncClientsButton}" Command="{Binding SyncCurrentMcpClientsCommand}" Background="#B7791F" Foreground="White" Padding="16,10" VerticalAlignment="Top" />
              </Grid>
            </Border>
            <Border Grid.Row="1" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <TextBlock Grid.Row="0" Text="{Binding Text.Mcp.ManifestEditorTitle}" FontSize="16" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Text="{Binding McpManifestEditor}" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinHeight="220" FontFamily="Consolas" />
              </Grid>
            </Border>
            <Border Grid.Row="2" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
                <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" RowSpacing="12">
                  <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock Text="{Binding Text.Mcp.ValidationResultsTitle}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding McpValidationSummaryDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                  </StackPanel>
                  <ItemsControl Grid.Row="1" ItemsSource="{Binding McpClientStatuses}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="#F8F4EA" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Client}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="#486581" />
                            <TextBlock Text="{Binding FilePath}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Border Grid.Row="2" Background="#F8F4EA" CornerRadius="12" Padding="12">
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding McpValidationIssues}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="#FFFDF8" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Severity}" FontSize="12" Foreground="#7B341E" />
                                <TextBlock Text="{Binding Details}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FilePath}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                </Grid>
                <Border Grid.Column="1" Background="#F8F4EA" CornerRadius="12" Padding="12">
                  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                    <StackPanel Grid.Row="0" Spacing="6">
                      <TextBlock Text="{Binding Text.Mcp.ExternalImportTitle}" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Text.Mcp.ExternalImportDescription}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                      <CheckBox Content="{Binding Text.Mcp.SyncImportedClientsLabel}" IsChecked="{Binding SyncImportedExternalServers}" />
                      <Button Content="{Binding Text.Mcp.ImportSelectedButton}" Command="{Binding ImportExternalMcpCommand}" Background="#2F855A" Foreground="White" HorizontalAlignment="Left" />
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="{Binding McpValidationScopeDisplay}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="2" MaxHeight="360" VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding McpExternalServerImports}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="#FFFDF8" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                              <StackPanel Spacing="6">
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ConflictDisplay}" FontSize="12" Foreground="#7B341E" />
                                <ComboBox ItemsSource="{Binding VariantOptions}" SelectedItem="{Binding SelectedVariantOption}">
                                  <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                      <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                  </ComboBox.ItemTemplate>
                                </ComboBox>
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>
            </Border>
            <Border Grid.Row="3" Background="#FFFDF8" CornerRadius="20" Padding="20">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <TextBlock Grid.Row="0" Text="{Binding Text.Mcp.GeneratedPreviewTitle}" FontSize="16" FontWeight="SemiBold" />
                <TabControl Grid.Row="1">
                  <TabItem Header="Claude">
                    <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="0,12,0,0">
                      <TextBlock Grid.Row="0" Text="{Binding McpClaudePathDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                      <TextBox Grid.Row="1" Text="{Binding McpClaudePreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                    </Grid>
                  </TabItem>
                  <TabItem Header="Codex">
                    <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="0,12,0,0">
                      <TextBlock Grid.Row="0" Text="{Binding McpCodexPathDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                      <TextBox Grid.Row="1" Text="{Binding McpCodexPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                    </Grid>
                  </TabItem>
                  <TabItem Header="Antigravity">
                    <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="0,12,0,0">
                      <TextBlock Grid.Row="0" Text="{Binding McpAntigravityPathDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                      <TextBox Grid.Row="1" Text="{Binding McpAntigravityPreview}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                    </Grid>
                  </TabItem>
                </TabControl>
              </Grid>
            </Border>
          </Grid>
        </TabItem>
      </TabControl>
    </Grid>
  </ScrollViewer>
</UserControl>
