<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.SkillsTabView">
  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Border.panel-soft">
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="ListBox.card-grid ListBoxItem">
      <Setter Property="Width" Value="252" />
      <Setter Property="MinHeight" Value="108" />
      <Setter Property="Margin" Value="0,0,10,10" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="TabControl.side-nav TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Margin" Value="0,0,0,3" />
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="MinWidth" Value="82" />
    </Style>
    <Style Selector="TabControl.compact-tabs TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Margin" Value="0,0,5,0" />
      <Setter Property="MinHeight" Value="26" />
    </Style>
    <Style Selector="Border.panel TextBlock">
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Border.panel-soft TextBlock">
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Border.panel Button">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Border.panel-soft Button">
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="0,6,0,0" RowDefinitions="Auto,*" RowSpacing="10">
    <Border Grid.Row="0" Classes="panel">
      <Grid ColumnDefinitions="260,*" ColumnSpacing="12">
        <StackPanel Spacing="6">
          <TextBlock Text="当前操作对象" FontWeight="SemiBold" />
          <ComboBox x:Name="SkillsContextTargetComboBox"
                    ItemsSource="{Binding Context.TargetOptions}"
                    SelectedItem="{Binding Context.SelectedTarget}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Text="这里决定本页默认筛选对象，不会切换整个工作区。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Column="1" Classes="panel-soft">
          <StackPanel Spacing="4">
            <TextBlock Text="当前对象说明" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Context.CurrentContextDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <TabControl Grid.Row="1"
                DataContext="{Binding Vm}"
                Classes="side-nav"
                TabStripPlacement="Left"
                SelectedIndex="{Binding SelectedSkillsSectionIndex, Mode=TwoWay}">
      <TabItem Header="浏览">
        <Grid RowDefinitions="Auto,*" RowSpacing="10">
          <Border Classes="panel">
            <Grid ColumnDefinitions="176,208,*" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="分类筛选" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding SkillFilterOptions}" SelectedItem="{Binding SelectedSkillFilterOption}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="搜索" FontWeight="SemiBold" />
                <TextBox Text="{Binding SkillSearchText}" Watermark="按名称、路径、来源或分类搜索" />
              </StackPanel>
              <WrapPanel Grid.Column="2" HorizontalAlignment="Right">
                <Border Classes="panel-soft" Margin="0,0,10,0">
                  <StackPanel Spacing="2">
                    <TextBlock Text="已安装 Skills" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SkillsSummaryDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                </Border>
                <Border Classes="panel-soft">
                  <StackPanel Spacing="2">
                    <TextBlock Text="来源摘要" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SkillSourcesSummaryDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                </Border>
              </WrapPanel>
            </Grid>
          </Border>

          <Grid Grid.Row="1" ColumnDefinitions="*,296" ColumnSpacing="10">
            <Border Classes="panel">
              <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <StackPanel Spacing="4">
                  <TextBlock Text="Skills 工作区" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="在一个统一面板中浏览 Skill 分组、已安装 Skills 和来源扫描结果。" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <TabControl Grid.Row="1" Classes="compact-tabs" Background="Transparent">
                  <TabItem Header="分组">
                    <ScrollViewer Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
                      <ListBox Classes="card-grid" ItemsSource="{Binding SkillGroups}" SelectedItem="{Binding SelectedSkillGroup}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel />
                          </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding SkillCountDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                              <TextBlock Text="{Binding ProfileSummary}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                              <ItemsControl ItemsSource="{Binding ContainedSkillPaths}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </ScrollViewer>
                  </TabItem>
                  <TabItem Header="已安装">
                    <ScrollViewer Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
                      <ListBox Classes="card-grid" ItemsSource="{Binding InstalledSkills}" SelectedItem="{Binding SelectedInstalledSkill}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel />
                          </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding BindingSummaryDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" />
                              <TextBlock Text="{Binding RelativePath}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding SourceDisplay}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </ScrollViewer>
                  </TabItem>
                  <TabItem Header="来源">
                    <ScrollViewer Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
                      <ListBox Classes="card-grid" ItemsSource="{Binding SkillSources}" SelectedItem="{Binding SelectedSkillSource}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel />
                          </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding SourceDisplayName}" FontSize="15" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding KindDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" />
                              <TextBlock Text="{Binding LocationDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding LastScanDisplay}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </ScrollViewer>
                  </TabItem>
                </TabControl>
              </Grid>
            </Border>

            <Border Grid.Column="1" Classes="panel">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                  <Border x:Name="SkillsCurrentSkillPanel" Classes="panel-soft">
                    <StackPanel Spacing="6">
                      <TextBlock Text="当前 Skill" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedInstalledSkill.Name, TargetNullValue=未选择 Skill}" FontSize="15" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedSkillBindingSummaryDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding SelectedSkillDetailsDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding SkillInstallStatusDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PendingSkillBindingSaveTargetDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      <WrapPanel>
                        <Button x:Name="SkillsSaveSelectedBindingButton" Content="保存此 Skill 绑定" Command="{Binding SaveSkillBindingsCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                        <Button Content="{Binding Text.Skills.PreviewDiffButton}" Command="{Binding PreviewSkillDiffCommand}" Margin="0,0,12,12" />
                      </WrapPanel>
                    </StackPanel>
                  </Border>
                  <Border x:Name="SkillsCurrentGroupPanel" Classes="panel-soft">
                    <StackPanel Spacing="6">
                      <TextBlock Text="当前分组" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedSkillGroup.DisplayName, TargetNullValue=未选择分组}" FontSize="15" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedSkillGroup.SkillCountDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                      <TextBlock Text="{Binding SelectedSkillGroupBindingSummaryDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PendingSkillGroupBindingSaveTargetDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      <Button x:Name="SkillsSaveSelectedGroupBindingButton" Content="保存此分组绑定" Command="{Binding SaveSkillGroupBindingsCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource AccentForegroundBrush}" HorizontalAlignment="Left" />
                    </StackPanel>
                  </Border>
                  <Border x:Name="SkillsCurrentSourcePanel" Classes="panel-soft">
                    <StackPanel Spacing="6">
                      <TextBlock Text="当前来源" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedSkillSource.SourceDisplayName, TargetNullValue=未选择来源}" FontSize="15" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SelectedSkillSource.DiscoveredSkillSummary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding SelectedSkillSource.AvailableReferenceSummary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      <Button x:Name="SkillsScanSelectedSourceButton" Content="{Binding Text.Skills.ScanSourceButton}" Command="{Binding ScanSkillSourceCommand}" HorizontalAlignment="Left" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="绑定">
        <Grid ColumnDefinitions="*,300" ColumnSpacing="12">
          <Border Classes="panel">
            <TabControl Classes="compact-tabs" Background="Transparent">
              <TabItem Header="按 Skill">
                <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                  <ListBox Classes="card-grid" ItemsSource="{Binding InstalledSkills}" SelectedItem="{Binding SelectedInstalledSkill}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding BindingSummaryDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" />
                            <TextBlock Text="{Binding RelativePath}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                  </ListBox>
                </ScrollViewer>
              </TabItem>
              <TabItem Header="按分组">
                <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                  <ListBox Classes="card-grid" ItemsSource="{Binding SkillGroups}" SelectedItem="{Binding SelectedSkillGroup}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Spacing="6">
                          <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding SkillCountDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding ProfileSummary}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </ScrollViewer>
              </TabItem>
            </TabControl>
          </Border>

          <StackPanel Grid.Column="1" Spacing="12">
            <Border Classes="panel">
              <StackPanel Spacing="10">
                <TextBlock Text="正在编辑的 Skill" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedInstalledSkill.Name, TargetNullValue=未选择 Skill}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSkillDetailsDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="当前绑定" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSkillBindingSummaryDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                <TextBlock Text="勾选要发布到的范围" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding SkillBindingProfiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,0,0,6" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding PendingSkillBindingSaveTargetDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="取消全部勾选后将保留在库中，显示为未绑定。" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                <Button Content="保存此 Skill 绑定" Command="{Binding SaveSkillBindingsCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" HorizontalAlignment="Left" />
              </StackPanel>
            </Border>
            <Border Classes="panel">
              <StackPanel Spacing="10">
                <TextBlock Text="正在编辑的分组" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSkillGroup.DisplayName, TargetNullValue=未选择分组}" FontWeight="SemiBold" />
                <TextBlock Text="当前绑定" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSkillGroupBindingSummaryDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                <TextBlock Text="勾选要发布到的范围" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding SkillGroupBindingProfiles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,0,0,6" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding PendingSkillGroupBindingSaveTargetDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <Button Content="保存此分组绑定" Command="{Binding SaveSkillGroupBindingsCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource AccentForegroundBrush}" HorizontalAlignment="Left" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="来源">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid ColumnDefinitions="272,*,296" ColumnSpacing="12">
            <Border Classes="panel">
              <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Text.Skills.SourcesTitle}" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SkillSourcesSummaryDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding SkillSources}" SelectedItem="{Binding SelectedSkillSource}" BorderThickness="0" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Spacing="4">
                        <TextBlock Text="{Binding SourceDisplayName}" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock Text="{Binding KindDisplay}" FontSize="13" Foreground="{DynamicResource WarningBrush}" />
                        <TextBlock Text="{Binding LocationDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Grid.Column="1" Classes="panel">
              <StackPanel Spacing="10">
                <TextBlock Text="{Binding Text.Skills.SourceEditorTitle}" FontSize="15" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding Text.Skills.SourceNameLabel}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding SkillSourceLocalName}" Watermark="{Binding Text.Skills.SourceNameWatermark}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="{Binding Text.Skills.ScopeLabel}" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding SkillSourceProfileOptions}" SelectedItem="{Binding SelectedSkillSourceProfileOption}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="{Binding Text.Skills.SourceTypeLabel}" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding SkillSourceKindOptions}" SelectedItem="{Binding SelectedSkillSourceKindOption}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding Text.Skills.SourceAddressLabel}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding SkillSourceRepository}" Watermark="{Binding Text.Skills.SourceAddressWatermark}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="{Binding Text.Skills.PathLabel}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding SkillSourcePath}" Watermark="{Binding Text.Skills.PathWatermark}" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding Text.Skills.ReferenceLabel}" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding SelectedSkillSource.AvailableReferences}" SelectedItem="{Binding SelectedSkillSourceReferenceOption}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="引用路径" FontWeight="SemiBold" />
                    <TextBox Text="{Binding SkillSourceReference}" Watermark="{Binding Text.Skills.ReferenceWatermark}" />
                  </StackPanel>
                </Grid>
                <WrapPanel>
                  <Button x:Name="SkillsCheckSourceVersionsButton" Content="检查来源版本" Command="{Binding CheckSkillSourceVersionsCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button x:Name="SkillsUpgradeSourceVersionsButton" Content="升级来源版本" Command="{Binding UpgradeSkillSourceVersionsCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.ScanSourceButton}" Command="{Binding ScanSkillSourceCommand}" Margin="0,0,12,12" />
                </WrapPanel>
                <WrapPanel>
                  <Button x:Name="SkillsSaveSourceButton" Content="{Binding Text.Skills.SaveSourceButton}" Command="{Binding SaveSkillSourceCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.DeleteSourceButton}" Command="{Binding DeleteSkillSourceCommand}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.ClearSourceFormButton}" Command="{Binding ClearSkillSourceFormCommand}" Margin="0,0,12,12" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Grid.Column="2" Classes="panel">
              <StackPanel Spacing="12">
                <TextBlock Text="{Binding Text.Skills.ScanResultTitle}" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSkillSource.LastScanDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding SelectedSkillSource.DiscoveredSkillSummary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding SelectedSkillSource.AvailableReferenceSummary}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="已发现的 Skill 分组" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding SelectedSkillSource.DiscoveredSkillGroupSummaries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" Margin="0,0,0,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding SelectedSkillSource.LastDiscoveredSkills}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="维护">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
            <Border Classes="panel">
              <StackPanel Spacing="12">
                <TextBlock Text="{Binding Text.Skills.InstallRecordTitle}" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedSkillDetailsDisplay}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Skills.CustomizationModeLabel}" FontWeight="SemiBold" />
                  <ComboBox ItemsSource="{Binding SkillModeOptions}" SelectedItem="{Binding SelectedSkillModeOption}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Skills.BindSourceLabel}" FontWeight="SemiBold" />
                  <ComboBox ItemsSource="{Binding SkillSources}" SelectedItem="{Binding SelectedSkillInstallSource}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding SourceDisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Skills.SourceSkillPathLabel}" FontWeight="SemiBold" />
                  <TextBox Text="{Binding SkillInstallSourcePath}" Watermark="{Binding Text.Skills.SourceSkillPathWatermark}" />
                </StackPanel>
                <WrapPanel>
                  <Button Content="{Binding Text.Skills.SaveInstallButton}" Command="{Binding SaveSkillInstallCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.DeleteInstallButton}" Command="{Binding DeleteSkillInstallCommand}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.CaptureBaselineButton}" Command="{Binding CaptureSkillBaselineCommand}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.PreviewDiffButton}" Command="{Binding PreviewSkillDiffCommand}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.PreviewMergeButton}" Command="{Binding PreviewOverlayMergeCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.ApplyMergeButton}" Command="{Binding ApplyOverlayMergeCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.SafeSyncButton}" Command="{Binding SyncSkillCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource AccentForegroundBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.ForceSyncButton}" Command="{Binding ForceSyncSkillCommand}" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12" />
                  <Button Content="{Binding Text.Skills.RollbackButton}" Command="{Binding RollbackSkillCommand}" Margin="0,0,12,12" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Spacing="12">
              <Border Classes="panel">
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding Text.Skills.CurrentStatusTitle}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SkillInstallStatusDisplay}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SkillInstallSourceDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SkillInstallBaselineDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedInstalledSkill.LastSyncDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedInstalledSkill.BackupSummaryDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Text.Skills.BackupsTitle}" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <ListBox ItemsSource="{Binding SelectedInstalledSkill.BackupRecords}" SelectedItem="{Binding SelectedSkillBackup}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding PathDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <TextBlock Text="{Binding Text.Skills.MergeTitle}" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <TextBlock Text="{Binding SkillMergeSummaryDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Text.Shell.RecentOperationsTitle}" FontWeight="SemiBold" Margin="0,6,0,0" />
                  <TextBox Text="{Binding OperationDetails}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" MinHeight="200" FontFamily="Consolas" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
