<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.SettingsTabView">
  <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
    <Grid ColumnDefinitions="*,360" ColumnSpacing="20">
      <StackPanel Grid.Column="0" Spacing="16">
        <Border Background="#FFFDF8" CornerRadius="20" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Text.Settings.HubRootTitle}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding HubRootDisplay}" TextWrapping="Wrap" Foreground="#486581" />
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
              <TextBox Text="{Binding HubRootInput}" Watermark="{Binding Text.Settings.HubRootWatermark}" />
              <Button Grid.Column="1" Content="{Binding Text.Settings.ChooseDirectoryButton}" Command="{Binding ChooseHubRootFolderCommand}" Background="#D9E2EC" Foreground="#102A43" Padding="16,8" />
              <Button Grid.Column="2" Content="{Binding Text.Settings.SwitchRootButton}" Command="{Binding SaveHubRootCommand}" Background="#1F487E" Foreground="White" Padding="16,8" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Background="#FFFDF8" CornerRadius="20" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Text.Settings.ConsoleSettingsTitle}" FontSize="18" FontWeight="SemiBold" />
            <CheckBox Content="{Binding Text.Settings.AutoStartManagedMcpLabel}" IsChecked="{Binding AutoStartManagedMcpOnLoad}" />
            <CheckBox Content="{Binding Text.Settings.AutoCheckSkillsLabel}" IsChecked="{Binding AutoCheckSkillUpdatesOnLoad}" />
            <CheckBox Content="{Binding Text.Settings.AutoSyncSkillsLabel}" IsChecked="{Binding AutoSyncSafeSkillsOnLoad}" />
            <WrapPanel>
              <Button x:Name="SettingsSaveButton" Content="{Binding Text.Settings.SaveSettingsButton}" Command="{Binding SaveAutomationSettingsCommand}" Background="#2F855A" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Settings.SwitchGlobalScopeButton}" Command="{Binding SwitchToGlobalScopeCommand}" Background="#7B341E" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Settings.SwitchCurrentProjectScopeButton}" Command="{Binding SwitchToSelectedProjectScopeCommand}" Background="#285E61" Foreground="White" Margin="0,0,12,12" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Background="#FFFDF8" CornerRadius="20" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Text.Settings.DiagnosticsTitle}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Text.Settings.DiagnosticsDescription}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
            <Border Background="#F8F4EA" CornerRadius="16" Padding="14">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding Text.Settings.DiagnosticsSummaryTitle}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DiagnosticsSummaryDisplay}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                <TextBlock Text="{Binding Text.Settings.DiagnosticsRootLabel}" FontSize="12" Foreground="#486581" />
                <TextBlock Text="{Binding DiagnosticsRootDisplay}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="{Binding Text.Settings.LatestStartupFailureTitle}" FontWeight="SemiBold" />
                <TextBox Text="{Binding LatestStartupFailureDisplay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="{Binding Text.Settings.LatestUnhandledExceptionTitle}" FontWeight="SemiBold" />
                <TextBox Text="{Binding LatestUnhandledExceptionDisplay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96" />
              </StackPanel>
            </Grid>
            <TextBox Text="{Binding DiagnosticsPackagePath}" Watermark="{Binding Text.Settings.DiagnosticsPathWatermark}" />
            <WrapPanel>
              <Button Content="{Binding Text.Settings.ChooseDiagnosticsExportButton}" Command="{Binding ChooseDiagnosticsPackageSaveCommand}" Background="#D9E2EC" Foreground="#102A43" Margin="0,0,12,12" />
              <Button x:Name="DiagnosticsExportButton" Content="{Binding Text.Settings.ExportDiagnosticsButton}" Command="{Binding ExportDiagnosticsCommand}" Background="#1F487E" Foreground="White" Margin="0,0,12,12" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Background="#FFFDF8" CornerRadius="20" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Text.Settings.SecurityTitle}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Text.Settings.SecurityDescription}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
              <Border Grid.Column="0" Background="#F8F4EA" CornerRadius="14" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Settings.ScriptRiskTitle}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ScriptRiskConsentDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Background="#F8F4EA" CornerRadius="14" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Settings.ManagedMcpRiskTitle}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ManagedMcpRiskConsentDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Background="#F8F4EA" CornerRadius="14" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Text.Settings.ExternalMcpRiskTitle}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ExternalMcpRiskConsentDisplay}" TextWrapping="Wrap" Foreground="#486581" />
                </StackPanel>
              </Border>
            </Grid>
            <Button x:Name="ResetRiskConfirmationsButton" Content="{Binding Text.Settings.ResetRiskConfirmationsButton}" Command="{Binding ResetRiskConfirmationsCommand}" Background="#B7791F" Foreground="White" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <Border Background="#FFFDF8" CornerRadius="20" Padding="20">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Text.Settings.PackageTitle}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Text.Settings.PackageDescription}" FontSize="12" Foreground="#486581" TextWrapping="Wrap" />
            <TextBox Text="{Binding SettingsPackagePath}" Watermark="{Binding Text.Settings.PackagePathWatermark}" />
            <WrapPanel>
              <Button Content="{Binding Text.Settings.ChooseExportButton}" Command="{Binding ChooseSettingsPackageSaveCommand}" Background="#D9E2EC" Foreground="#102A43" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Settings.ChooseImportButton}" Command="{Binding ChooseSettingsPackageOpenCommand}" Background="#D9E2EC" Foreground="#102A43" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Settings.ExportButton}" Command="{Binding ExportConfigurationPackageCommand}" Background="#1F487E" Foreground="White" Margin="0,0,12,12" />
              <Button Content="{Binding Text.Settings.ImportButton}" Command="{Binding ImportConfigurationPackageCommand}" Background="#B7791F" Foreground="White" Margin="0,0,12,12" />
            </WrapPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <Border Grid.Column="1" Background="#F8F4EA" CornerRadius="16" Padding="16">
        <Grid RowDefinitions="Auto,*" RowSpacing="10">
          <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="{Binding Text.Shell.RecentOperationsTitle}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
          </StackPanel>
          <TextBox Grid.Row="1" Text="{Binding OperationDetails}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" MinHeight="320" />
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>