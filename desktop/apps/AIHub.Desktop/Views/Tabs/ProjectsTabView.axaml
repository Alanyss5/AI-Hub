<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.ProjectsTabView">
  <Grid DataContext="{Binding Vm}" Margin="0,16,0,0" ColumnDefinitions="320,*" ColumnSpacing="20">
    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Padding="20">
      <Grid RowDefinitions="Auto,*" RowSpacing="12">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Spacing="4">
            <TextBlock Text="项目列表" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ProjectCountDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
          <Button Grid.Column="1"
                  Content="刷新"
                  Command="{Binding RefreshCommand}"
                  Background="{DynamicResource NeutralButtonBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  Padding="16,8" />
        </Grid>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Projects}"
                 SelectedItem="{Binding SelectedProject}"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                  <TextBlock Text="{Binding Path}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding Profile}" FontSize="12" Foreground="{DynamicResource WarningBrush}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Padding="24">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
        <TextBlock Text="项目资料" FontSize="18" FontWeight="SemiBold" />
        <Grid Grid.Row="1" ColumnDefinitions="*,300" ColumnSpacing="20">
          <StackPanel Spacing="16">
            <StackPanel Spacing="6">
              <TextBlock Text="项目名称" FontWeight="SemiBold" />
              <TextBox Text="{Binding ProjectName}" Watermark="例如：OverSeaFramework" />
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="项目目录" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBox Text="{Binding ProjectPath}" Watermark="选择本地项目目录" />
                <Button Grid.Column="1"
                        Content="选择目录"
                        Command="{Binding ChooseProjectFolderCommand}"
                        Background="{DynamicResource NeutralButtonBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Padding="16,8" />
              </Grid>
            </StackPanel>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Profile" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding ProfileOptions}" SelectedItem="{Binding SelectedProfileOption}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{Binding ProjectProfileValidationDisplay}"
                           FontSize="12"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasProjectProfileValidationWarning}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Bottom">
                <CheckBox Content="置顶此项目" IsChecked="{Binding IsPinned}" />
              </StackPanel>
            </Grid>
          </StackPanel>

          <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="16">
            <StackPanel Spacing="10">
              <Button x:Name="ProjectsSaveButton"
                      Content="保存项目资料"
                      Command="{Binding SaveProjectCommand}"
                      Background="{DynamicResource AccentBrush}"
                      Foreground="{DynamicResource AccentForegroundBrush}"
                      Padding="16,10" />
              <Button x:Name="ProjectsDeleteButton"
                      Content="删除所选项目"
                      Command="{Binding DeleteSelectedProjectCommand}"
                      Background="{DynamicResource NeutralButtonBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Padding="16,10" />
              <Button x:Name="ProjectsClearFormButton"
                      Content="清空表单"
                      Command="{Binding ClearFormCommand}"
                      Background="{DynamicResource NeutralButtonBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Padding="16,10" />
            </StackPanel>
          </Border>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="16">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
            <TextBlock Text="操作反馈" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1"
                       Text="{Binding OperationSummary}"
                       TextWrapping="Wrap" />
            <TextBox Grid.Row="2"
                     Text="{Binding OperationDetails}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="96"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
