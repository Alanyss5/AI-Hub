<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.ProjectsTabView">
  <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
    <Grid ColumnDefinitions="320,*,360" ColumnSpacing="20">
      <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Padding="20">
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding Text.Projects.ListTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding ProjectCountDisplay}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{Binding Text.Projects.RefreshButton}"
                    Command="{Binding RefreshCommand}"
                    Background="{DynamicResource NeutralButtonBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Padding="16,8" />
          </Grid>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Projects}"
                   SelectedItem="{Binding SelectedProject}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="{Binding Path}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Profile}" FontSize="12" Foreground="{DynamicResource WarningBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Padding="24">
        <StackPanel Spacing="16">
          <TextBlock Text="{Binding Text.Projects.FormTitle}" FontSize="18" FontWeight="SemiBold" />
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Text.Projects.NameLabel}" FontWeight="SemiBold" />
            <TextBox Text="{Binding ProjectName}" Watermark="{Binding Text.Projects.NameWatermark}" />
          </StackPanel>
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Text.Projects.DirectoryLabel}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBox Text="{Binding ProjectPath}" Watermark="{Binding Text.Projects.DirectoryWatermark}" />
              <Button Grid.Column="1"
                      Content="{Binding Text.Projects.ChooseDirectoryButton}"
                      Command="{Binding ChooseProjectFolderCommand}"
                      Background="{DynamicResource NeutralButtonBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Padding="16,8" />
            </Grid>
          </StackPanel>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="6">
              <TextBlock Text="{Binding Text.Projects.ProfileLabel}" FontWeight="SemiBold" />
              <ComboBox ItemsSource="{Binding ProfileOptions}" SelectedItem="{Binding SelectedProfileOption}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="{Binding ProjectProfileValidationDisplay}"
                         FontSize="12"
                         Foreground="{DynamicResource DangerBrush}"
                         TextWrapping="Wrap"
                         IsVisible="{Binding HasProjectProfileValidationWarning}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Bottom">
              <CheckBox Content="{Binding Text.Projects.PinLabel}" IsChecked="{Binding IsPinned}" />
            </StackPanel>
          </Grid>
          <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding Text.Projects.WorkspaceStatusTitle}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Text.Projects.RuntimeIdentityTitle}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding Text.Projects.BuildSourceLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding RuntimeBuildIdentityDisplay}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Text.Projects.ExecutablePathLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding RuntimeExecutablePathDisplay}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Text.Settings.HubRootTitle}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding HubRootDisplay}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Text.Projects.ScopeLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding ActiveScopeDisplay}" />
              <TextBlock Text="{Binding Text.Shell.DefaultProfileLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding DefaultProfileDisplay}" />
              <TextBlock Text="{Binding Text.Shell.RecentProjectLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding LastOpenedProjectDisplay}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Text.Projects.GlobalOnboardingLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding GlobalOnboardingStatusDisplay}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Text.Projects.ProjectOnboardingLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding ProjectOnboardingStatusDisplay}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding Text.Projects.WorkspaceBindingTitle}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Text.Projects.WorkspaceBindingModeLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding ProjectWorkspaceBindingModeDisplay}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding ProjectWorkspaceBindingWarningDisplay}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource DangerBrush}"
                         IsVisible="{Binding HasProjectWorkspaceBindingWarning}" />
              <TextBox Text="{Binding ProjectWorkspaceBindingDetails}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       MinHeight="180" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
          <TextBlock Grid.Row="0" Text="{Binding Text.Projects.ActionCenterTitle}" FontSize="18" FontWeight="SemiBold" />
          <StackPanel Grid.Row="1" Spacing="10">
            <Button x:Name="ProjectsSaveButton" Content="{Binding Text.Projects.SaveProjectButton}" Command="{Binding SaveProjectCommand}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.ApplySelectedProfileButton}" Command="{Binding ApplyProjectProfileCommand}" Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.SetCurrentProjectButton}" Command="{Binding SetCurrentProjectCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.SwitchProjectScopeButton}" Command="{Binding SwitchToSelectedProjectScopeCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.SwitchGlobalScopeButton}" Command="{Binding SwitchToGlobalScopeCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.ApplyGlobalLinksButton}" Command="{Binding ApplyGlobalLinksCommand}" Background="{DynamicResource SurfaceStrongBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button x:Name="ProjectsRescanGlobalOnboardingButton" Content="{Binding Text.Projects.RescanGlobalOnboardingButton}" Command="{Binding RescanGlobalOnboardingCommand}" Background="{DynamicResource WarningBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button x:Name="ProjectsRescanProjectOnboardingButton" Content="{Binding Text.Projects.RescanProjectOnboardingButton}" Command="{Binding RescanProjectOnboardingCommand}" Background="{DynamicResource InfoBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.DeleteSelectedButton}" Command="{Binding DeleteSelectedProjectCommand}" Background="{DynamicResource NeutralButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
            <Button Content="{Binding Text.Projects.ClearFormButton}" Command="{Binding ClearFormCommand}" Background="{DynamicResource NeutralButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" />
          </StackPanel>
          <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="16">
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
              <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="{Binding Text.Projects.ResultTitle}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
              </StackPanel>
              <TextBox Grid.Row="1"
                       Text="{Binding OperationDetails}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       MinHeight="220" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
