<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIHub.Desktop.Views.Tabs.ProjectsTabView">
  <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
    <Grid ColumnDefinitions="320,*,360" ColumnSpacing="20">
      <Border Grid.Column="0" Background="#FFFDF8" CornerRadius="20" Padding="20">
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding Text.Projects.ListTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding ProjectCountDisplay}" FontSize="12" Foreground="#486581" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{Binding Text.Projects.RefreshButton}"
                    Command="{Binding RefreshCommand}"
                    Background="#D9E2EC"
                    Foreground="#102A43"
                    Padding="16,8" />
          </Grid>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Projects}"
                   SelectedItem="{Binding SelectedProject}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="#F8F4EA" CornerRadius="16" Padding="14" Margin="0,0,0,10">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="{Binding Path}" TextWrapping="Wrap" FontSize="12" Foreground="#486581" />
                    <TextBlock Text="{Binding Profile}" FontSize="12" Foreground="#7B341E" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Background="#FFFDF8" CornerRadius="20" Padding="24">
        <StackPanel Spacing="16">
          <TextBlock Text="{Binding Text.Projects.FormTitle}" FontSize="18" FontWeight="SemiBold" />
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Text.Projects.NameLabel}" FontWeight="SemiBold" />
            <TextBox Text="{Binding ProjectName}" Watermark="{Binding Text.Projects.NameWatermark}" />
          </StackPanel>
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Text.Projects.DirectoryLabel}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBox Text="{Binding ProjectPath}" Watermark="{Binding Text.Projects.DirectoryWatermark}" />
              <Button Grid.Column="1"
                      Content="{Binding Text.Projects.ChooseDirectoryButton}"
                      Command="{Binding ChooseProjectFolderCommand}"
                      Background="#D9E2EC"
                      Foreground="#102A43"
                      Padding="16,8" />
            </Grid>
          </StackPanel>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="6">
              <TextBlock Text="{Binding Text.Projects.ProfileLabel}" FontWeight="SemiBold" />
              <ComboBox ItemsSource="{Binding ProfileOptions}" SelectedItem="{Binding SelectedProfileOption}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Bottom">
              <CheckBox Content="{Binding Text.Projects.PinLabel}" IsChecked="{Binding IsPinned}" />
            </StackPanel>
          </Grid>
          <Border Background="#F8F4EA" CornerRadius="16" Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding Text.Projects.WorkspaceStatusTitle}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Text.Projects.ScopeLabel}" FontSize="12" Foreground="#486581" />
              <TextBlock Text="{Binding ActiveScopeDisplay}" />
              <TextBlock Text="{Binding Text.Shell.DefaultProfileLabel}" FontSize="12" Foreground="#486581" />
              <TextBlock Text="{Binding DefaultProfileDisplay}" />
              <TextBlock Text="{Binding Text.Shell.RecentProjectLabel}" FontSize="12" Foreground="#486581" />
              <TextBlock Text="{Binding LastOpenedProjectDisplay}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Background="#FFFDF8" CornerRadius="20" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
          <TextBlock Grid.Row="0" Text="{Binding Text.Projects.ActionCenterTitle}" FontSize="18" FontWeight="SemiBold" />
          <StackPanel Grid.Row="1" Spacing="10">
            <Button x:Name="ProjectsSaveButton" Content="{Binding Text.Projects.SaveProjectButton}" Command="{Binding SaveProjectCommand}" Background="#1F487E" Foreground="White" Padding="16,10" />
            <Button Content="{Binding Text.Projects.ApplySelectedProfileButton}" Command="{Binding ApplyProjectProfileCommand}" Background="#2F855A" Foreground="White" Padding="16,10" />
            <Button Content="{Binding Text.Projects.SetCurrentProjectButton}" Command="{Binding SetCurrentProjectCommand}" Background="#B7791F" Foreground="White" Padding="16,10" />
            <Button Content="{Binding Text.Projects.SwitchProjectScopeButton}" Command="{Binding SwitchToSelectedProjectScopeCommand}" Background="#285E61" Foreground="White" Padding="16,10" />
            <Button Content="{Binding Text.Projects.SwitchGlobalScopeButton}" Command="{Binding SwitchToGlobalScopeCommand}" Background="#7B341E" Foreground="White" Padding="16,10" />
            <Button Content="{Binding Text.Projects.ApplyGlobalLinksButton}" Command="{Binding ApplyGlobalLinksCommand}" Background="#5A4A42" Foreground="White" Padding="16,10" />
            <Button Content="{Binding Text.Projects.DeleteSelectedButton}" Command="{Binding DeleteSelectedProjectCommand}" Background="#D9E2EC" Foreground="#102A43" Padding="16,10" />
            <Button Content="{Binding Text.Projects.ClearFormButton}" Command="{Binding ClearFormCommand}" Background="#D9E2EC" Foreground="#102A43" Padding="16,10" />
          </StackPanel>
          <Border Grid.Row="2" Background="#F8F4EA" CornerRadius="16" Padding="16">
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
              <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="{Binding Text.Projects.ResultTitle}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
              </StackPanel>
              <TextBox Grid.Row="1"
                       Text="{Binding OperationDetails}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       MinHeight="220" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
